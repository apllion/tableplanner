# Frontend
VITE_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
VITE_EVENT_START=2026-03-20

# Passphrase gate (Node backend only; for Apps Script, set as Script Property)
PASSPHRASE_ANSWER=changeme

# Storage backend: "file" or "sheets"
STORAGE_BACKEND=file

# Google Sheets backend (when STORAGE_BACKEND=sheets)
GOOGLE_SHEETS_ID=your-spreadsheet-id
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# Standalone server
CORS_ORIGIN=http://localhost:5173
PORT=3000
